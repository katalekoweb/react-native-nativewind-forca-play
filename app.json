{
  "expo": {
    "name": "Jogo da Letra Viva",
    "description": "Jogo para testar o seu vocabulário com desafios divertidos e vários níveis",
    "slug": "letraviva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": ["android", "ios"],
    "primaryColor": "#67C090",
    "backgroundColor": "#454545",
    "scheme": "letraviva",
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#67C090"
    },
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/icon.png",
        "light": "./assets/icon.png"
      },
      "bundleIdentifier": "com.anonymous.letraviva"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#67C090"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.katalekodev.letraviva"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d047ac23-8cf5-43f1-87a5-e7f1ac9f4dcb"
      }
    }
  }
}
